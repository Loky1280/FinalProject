<UserControl x:Class="FinalProject.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <StackPanel MaxWidth="430"
                    VerticalAlignment="Center">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />

            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="Складність за замовчуванням:" />
                <ComboBox Width="160"
                          Margin="0,8,0,0"
                          HorizontalAlignment="Left"
                          ItemsSource="{Binding Difficulties}"
                          SelectedItem="{Binding SelectedDifficulty}" />
            </StackPanel>

            <CheckBox Margin="0,16,0,0"
                      Content="Показувати таймер"
                      IsChecked="{Binding ShowTimer}" />

            <CheckBox Margin="0,8,0,0"
                      Content="Підсвічувати конфлікти"
                      IsChecked="{Binding HighlightConflicts}" />

            <StackPanel Margin="0,18,0,0"
                        Orientation="Horizontal">
                <Button Width="120"
                        Height="32"
                        Command="{Binding SaveCommand}"
                        Content="Зберегти" />
                <Button Width="120"
                        Height="32"
                        Margin="10,0,0,0"
                        Command="{Binding ReloadCommand}"
                        Content="Оновити" />
            </StackPanel>

            <TextBlock Margin="0,12,0,0"
                       Foreground="#556070"
                       Text="{Binding StatusMessage}" />
        </StackPanel>
    </Grid>
</UserControl>
