<UserControl x:Class="FinalProject.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#2B5FB8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding Title}" />

        <StackPanel Grid.Row="1"
                    Margin="0,16,0,16"
                    Orientation="Horizontal">
            <TextBlock Margin="0,0,10,0"
                       VerticalAlignment="Center"
                       Text="Складність:" />
            <ComboBox Width="140"
                      Height="32"
                      Padding="8,0"
                      ItemsSource="{Binding Difficulties}"
                      SelectedItem="{Binding SelectedDifficulty}" />
            <Button Width="110"
                    Margin="12,0,0,0"
                    Style="{StaticResource ControlButtonStyle}"
                    Command="{Binding NewGameCommand}"
                    Content="Нова гра" />
            <Button Width="120"
                    Style="{StaticResource ControlButtonStyle}"
                    Command="{Binding PauseResumeCommand}"
                    Content="{Binding PauseButtonText}" />
            <Button Width="110"
                    Style="{StaticResource ControlButtonStyle}"
                    Command="{Binding SaveGameCommand}"
                    Content="Зберегти" />
            <Button Width="120"
                    Style="{StaticResource ControlButtonStyle}"
                    Command="{Binding LoadGameCommand}"
                    Content="Завантажити" />
            <TextBlock Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1E2B3A"
                       Text="{Binding ElapsedTimeDisplay}"
                       Visibility="{Binding ShowTimer, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <Border Grid.Row="2"
                Width="460"
                Height="460"
                Padding="8"
                HorizontalAlignment="Left"
                BorderBrush="#1E2B3A"
                BorderThickness="2"
                CornerRadius="6"
                IsEnabled="{Binding IsBoardInteractionEnabled}">
            <ItemsControl ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="9" Rows="9" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#516278"
                                BorderThickness="{Binding CellBorderThickness}">
                            <TextBox HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     FontSize="20"
                                     FontWeight="SemiBold"
                                     BorderThickness="0"
                                     Padding="0"
                                     MaxLength="1"
                                     IsReadOnly="{Binding IsFixed}"
                                     Text="{Binding InputValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="Foreground" Value="#1A2533" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFixed}" Value="True">
                                                <Setter Property="Background" Value="#E9EEF5" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsConflict}" Value="True">
                                                <Setter Property="Background" Value="#FFE7E7" />
                                                <Setter Property="Foreground" Value="#B00020" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <TextBlock Grid.Row="3"
                   Margin="0,16,0,0"
                   Foreground="#495A6E"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>
